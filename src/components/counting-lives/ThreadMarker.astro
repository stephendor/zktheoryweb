---
/**
 * ThreadMarker.astro — Task 2.2c — Agent_Design_Templates
 *
 * Renders colour-coded thread indicator pills for Counting Lives chapter hero.
 * Pure Astro component — no client-side JS required.
 *
 * Props:
 *   threads — string[] — array of thread slugs from chapter frontmatter
 *
 * Thread slug → accent colour mapping:
 *   scottish-thread → var(--color-cl-red)
 *   gender-thread   → var(--color-cl-ochre)
 *   (unrecognised)  → var(--color-neutral-border) fallback
 *
 * Each pill links to /counting-lives/threads/{slug}/.
 * Slug is formatted as a readable label (hyphens → spaces, title-case).
 * Wrapped in a <nav> with aria-label="Chapter threads" for accessibility.
 */

interface Props {
  threads: string[];
}

const { threads } = Astro.props;

const THREAD_COLORS: Record<string, string> = {
  'scottish-thread': 'var(--color-cl-red)',
  'gender-thread':   'var(--color-cl-ochre)',
};

function slugToLabel(slug: string): string {
  return slug
    .split('-')
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

function getColor(slug: string): string {
  return THREAD_COLORS[slug] ?? 'var(--color-neutral-border)';
}
---

{threads.length > 0 && (
  <nav class="thread-marker" aria-label="Chapter threads">
    {threads.map((slug) => (
      <a
        href={`/counting-lives/threads/${slug}/`}
        class="thread-marker-pill"
        style={`--thread-color: ${getColor(slug)}`}
      >
        {slugToLabel(slug)}
      </a>
    ))}
  </nav>
)}

<style>
  /* ── Container ─────────────────────────────────────────────────────────── */
  .thread-marker {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  /* ── Pill link ─────────────────────────────────────────────────────────── */
  .thread-marker-pill {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 500;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    /* Colour-coded left border; thin neutral border on remaining sides */
    border-left: 3px solid var(--thread-color);
    border-top: 1px solid var(--color-neutral-border);
    border-right: 1px solid var(--color-neutral-border);
    border-bottom: 1px solid var(--color-neutral-border);
    color: var(--color-neutral-body);
    text-decoration: none;
    line-height: var(--leading-snug);
    background-color: var(--color-neutral-surface);
    transition: background-color 150ms ease;
  }

  .thread-marker-pill:hover {
    background-color: var(--color-neutral-subtle);
  }

  .thread-marker-pill:focus-visible {
    outline: 2px solid var(--thread-color);
    outline-offset: 2px;
    border-radius: var(--radius-full);
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .thread-marker-pill {
      transition: none;
    }
  }
</style>
