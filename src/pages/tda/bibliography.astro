---
/**
 * tda/bibliography.astro — Task 2.9b — Agent_Integration
 *
 * Bibliography page for the TDA section.
 * Extends BaseLayout; renders all bibliography items using the TDA palette.
 *
 * Tag filtering note: The Zotero cache contains only generic Library of Congress
 * subject headings (e.g. "Great Britain", "Poor", "History") — no project-specific
 * tags such as 'tda-methods' or 'topology' were found. The full unfiltered
 * bibliography is rendered. When the Zotero library is tagged with project-specific
 * tags, update the `filter()` call below to match them.
 *
 * Accent: --color-tda-teal (TDA / Mathematical palette)
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import BibliographyList from '@components/shared/BibliographyList.astro';
import { getBibliographyByCollection, getBibliographyItems } from '@lib/bibliography';

// Filter by Zotero collection name. Falls back to full library until
// 'fetchZoteroLibrary' populates the collections map in the JSON cache.
const items = getBibliographyByCollection('TDA-Research');
const isFiltered = items.length < getBibliographyItems().length;
---

<BaseLayout
  title="Bibliography — Topological Data Analysis"
  description="Full bibliography for the TDA research project applying persistent homology to poverty measurement."
  section="tda"
>
  <div class="container-prose">
    <header class="biblio-header">
      <h1>Bibliography</h1>
      <p class="biblio-subtitle">
        Sources cited and consulted in the TDA research programme.
      </p>
      {!isFiltered && (
        <p class="biblio-note">
          Showing full library ({items.length} items). Items will be filtered by
          project tags once the Zotero library is tagged.
        </p>
      )}
    </header>

    <BibliographyList
      items={items}
      accentColor="var(--color-tda-teal)"
    />
  </div>
</BaseLayout>

<style>
  .container-prose {
    max-width: var(--prose-width, 65ch);
    margin: 0 auto;
    padding: var(--space-8) var(--space-4);
  }

  .biblio-header {
    margin-bottom: var(--space-10);
    padding-bottom: var(--space-8);
    border-bottom: 2px solid var(--color-tda-teal);
  }

  .biblio-header h1 {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    color: var(--color-neutral-heading);
    margin: 0 0 var(--space-3) 0;
  }

  .biblio-subtitle {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-neutral-muted);
    margin: 0 0 var(--space-3) 0;
  }

  .biblio-note {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--color-neutral-muted);
    background: color-mix(in srgb, var(--color-tda-teal) 8%, transparent);
    border-left: 3px solid var(--color-tda-teal);
    padding: var(--space-3) var(--space-4);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    margin: 0;
  }
</style>
