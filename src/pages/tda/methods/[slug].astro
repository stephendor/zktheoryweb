---
/**
 * src/pages/tda/methods/[slug].astro — Task 6.5-pre — Agent_Infra
 *
 * Dynamic route for TDA method detail pages.
 * URL: /tda/methods/{method_slug}  (e.g. /tda/methods/persistent-homology)
 *
 * getStaticPaths() uses entry.data.method_slug (not entry.id) for clean URLs.
 * Generates 6 routes for the 6 method MDX files.
 *
 * Layout: BaseLayout with section="tda" (no MethodLayout exists).
 * Connections: related_papers resolved via getCollection('papers');
 *              related_interludes resolved via getCollection('interludes').
 */

import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import ConnectionsPanel from '@components/shared/ConnectionsPanel.astro';

// ─── Static paths ─────────────────────────────────────────────────────────────

export async function getStaticPaths() {
  const allMethods = await getCollection('methods');

  return allMethods.map((entry) => ({
    params: { slug: entry.data.method_slug },
    props: { entry },
  }));
}

// ─── Props ────────────────────────────────────────────────────────────────────

interface Props {
  entry: CollectionEntry<'methods'>;
}

const { entry } = Astro.props;
const { title, status, related_papers, related_interludes } = entry.data;

const { Content } = await render(entry);

// ─── Status badge config ──────────────────────────────────────────────────────

const statusConfig: Record<string, { label: string; modifier: string }> = {
  drafting:    { label: 'Drafting',   modifier: 'planned' },
  'in-review': { label: 'In Review',  modifier: 'in-review' },
  complete:    { label: 'Complete',   modifier: 'published' },
};
const statusInfo = statusConfig[status] ?? { label: status, modifier: 'planned' };

// ─── Connections ──────────────────────────────────────────────────────────────

const allPapers = related_papers.length > 0 ? await getCollection('papers') : [];
const allInterludes = related_interludes.length > 0 ? await getCollection('interludes') : [];

const paperConnections = related_papers.map((n) => {
  const paper = allPapers.find((p) => p.data.paper_number === n);
  return paper
    ? { href: `/tda/papers/${paper.id}`, label: `Paper ${n}`, title: paper.data.title, palette: 'tda' as const }
    : { href: '#', label: `Paper ${n}`, title: `Paper ${n}`, palette: 'tda' as const, dataTodo: 'paper-not-found' };
});

const interludeConnections = related_interludes.map((slug) => {
  const interlude = allInterludes.find((i) => i.data.interlude_slug === slug);
  return interlude
    ? { href: `/counting-lives/interludes/${slug}`, label: 'Mathematical Interlude', title: interlude.data.title, palette: 'cl' as const }
    : { href: '#', label: 'Mathematical Interlude', title: slug, palette: 'cl' as const, dataTodo: 'interlude-not-found' };
});

const allConnections = [...paperConnections, ...interludeConnections];
---

<BaseLayout title={title} section="tda">

  {/* ══════════════════════════════════════════════════════════════════
      HERO — TDA palette band
      ══════════════════════════════════════════════════════════════════ */}
  <div class="method-hero">
    <div class="container-prose">

      <p class="method-eyebrow" aria-label="Content type: TDA Method">TDA Method</p>

      <h1 class="method-title">{title}</h1>

      <span
        class={`status-badge status-${statusInfo.modifier}`}
        aria-label={`Status: ${statusInfo.label}`}
      >
        {statusInfo.label}
      </span>

    </div>
  </div>

  {/* ══════════════════════════════════════════════════════════════════
      BODY — prose content
      ══════════════════════════════════════════════════════════════════ */}
  <div class="method-body">
    <div class="container-prose">
      <article class="prose">
        <Content />
      </article>

      {/* ── Cross-project connections ── */}
      {allConnections.length > 0 && (
        <ConnectionsPanel heading="Connections" connections={allConnections} />
      )}
    </div>
  </div>

</BaseLayout>

<style>
  /* ─── Hero band ─────────────────────────────────────────────────── */
  .method-hero {
    background-color: var(--color-tda-surface, var(--color-neutral-surface));
    border-bottom: 2px solid var(--color-tda-teal, var(--color-neutral-border));
    padding: var(--space-12) 0 var(--space-10);
  }

  .method-eyebrow {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-tda-teal, var(--color-neutral-muted));
    margin: 0 0 var(--space-3) 0;
  }

  .method-title {
    font-family: var(--font-serif);
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--color-neutral-text);
    margin: 0 0 var(--space-4) 0;
    line-height: var(--leading-tight);
  }

  /* ─── Body ──────────────────────────────────────────────────────── */
  .method-body {
    padding: var(--space-12) 0;
  }

  /* ─── Status badges (reuse paper pattern) ───────────────────────── */
  .status-badge {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: var(--space-1) var(--space-3);
    border-radius: 3px;
  }

  .status-planned    { background: var(--color-neutral-surface-alt); color: var(--color-neutral-muted); border: 1px solid var(--color-neutral-border); }
  .status-in-review  { background: #fef3c7; color: #92400e; border: 1px solid #fde68a; }
  .status-published  { background: #d1fae5; color: #065f46; border: 1px solid #6ee7b7; }
  .status-in-progress { background: #dbeafe; color: #1e40af; border: 1px solid #93c5fd; }
</style>
