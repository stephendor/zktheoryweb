---
/**
 * index.astro — Homepage — Task 2.8 — Agent_Design_Templates
 * Hero + two project cards + recent activity feed.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

const allChapters = await getCollection('chapters');
const allPapers   = await getCollection('papers');
const allEssays   = await getCollection('essays');
const allNotes    = await getCollection('notes');

// Featured editorial slots
const featuredChapter = allChapters
  .filter(ch => ch.data.featured && ch.id !== 'ch-00-sample')
  .at(0);

const featuredPaper = allPapers
  .filter(p => p.data.featured)
  .at(0);

// Latest non-draft writing entry (essays + notes merged, sorted by date desc)
type WritingEntry = { type: 'essay' | 'note'; slug: string; title: string; summary?: string; date: Date };

const writingEntries: WritingEntry[] = [
  ...allEssays
    .filter(e => !e.data.draft)
    .map(e => ({ type: 'essay' as const, slug: e.id, title: e.data.title, summary: e.data.summary, date: e.data.date })),
  ...allNotes
    .filter(n => !n.data.draft)
    .map(n => ({ type: 'note' as const, slug: n.id, title: n.data.title, summary: n.data.summary, date: n.data.date })),
];

const latestWriting = writingEntries
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .at(0);
---

<BaseLayout
  title="Home"
  description="Counting lives. Measuring poverty. Mapping trajectories. — An open research portfolio on the history of poverty measurement and topological data analysis."
  section="home"
>
  <!-- ── Hero ─────────────────────────────────────────────────────────────── -->
  <section class="hero" aria-labelledby="site-tagline">
    <div class="container-full hero__inner">
      <p class="hero__tagline" id="site-tagline">
        Counting lives.<br />
        Measuring poverty.<br />
        Mapping trajectories.
      </p>
      <p class="hero__subtitle">
        Two intertwined projects: a history of poverty measurement as political act,
        and topological data analysis revealing the shapes poverty leaves in data.
      </p>
    </div>
  </section>

  <!-- ── Project cards ─────────────────────────────────────────────────────── -->
  <section class="projects-section" aria-labelledby="projects-heading">
    <div class="container-viz projects-inner">
      <h2 class="sr-only" id="projects-heading">Research Programmes</h2>
      <div class="projects-grid">

        <article class="project-card project-card--cl">
          <h2 class="project-card__title">Counting Lives</h2>
          <p class="project-card__desc">
            A historical investigation into the politics of poverty measurement — from Rowntree's
            dietary surveys to modern multidimensional indices. This book traces how numbers about
            the poor have always carried the values of those who made them.
          </p>
          <a href="/counting-lives/" class="project-card__link card-link--cl">
            Explore Counting Lives →
          </a>
        </article>

        <article class="project-card project-card--tda">
          <h2 class="project-card__title">TDA Research Programme</h2>
          <p class="project-card__desc">
            A programme of topological data analysis applied to longitudinal UK household panel
            data. Ten linked papers applying Mapper, persistent homology, and graph-neural-network
            methods to employment and poverty trajectories.
          </p>
          <a href="/tda/" class="project-card__link card-link--tda">
            Explore the TDA Research Programme →
          </a>
        </article>

      </div>
    </div>
  </section>
  <!-- ── Selected work & writing ─────────────────────────────────────────── -->
  <section class="activity-section" aria-labelledby="activity-heading">
    <div class="container-prose activity-inner">
      <h2 class="activity-heading" id="activity-heading">Selected Work &amp; Writing</h2>

      <ul class="activity-list">
        {featuredChapter && (
          <li class="activity-item">
            <span class="activity-badge activity-badge--chapter">Chapter</span>
            <div class="activity-content">
              <a class="activity-title" href={`/counting-lives/ch-${featuredChapter.data.chapter_number}/`}>
                Ch. {featuredChapter.data.chapter_number} — {featuredChapter.data.title}
              </a>
              <p class="activity-desc">{featuredChapter.data.spine_role}</p>
            </div>
          </li>
        )}
        {featuredPaper && (
          <li class="activity-item">
            <span class="activity-badge activity-badge--paper">Paper</span>
            <div class="activity-content">
              <a class="activity-title" href={`/tda/papers/${featuredPaper.id}/`}>
                Paper {featuredPaper.data.paper_number} — {featuredPaper.data.title}
              </a>
              {featuredPaper.data.plain_summary && (
                <p class="activity-desc">{featuredPaper.data.plain_summary.slice(0, 100)}&hellip;</p>
              )}
            </div>
          </li>
        )}
        {latestWriting && (
          <li class="activity-item">
            <span class={`activity-badge activity-badge--${latestWriting.type}`}>
              {latestWriting.type === 'essay' ? 'Essay' : 'Note'}
            </span>
            <div class="activity-content">
              <a class="activity-title" href={`/writing/${latestWriting.slug}/`}>
                {latestWriting.title}
              </a>
              {latestWriting.summary && (
                <p class="activity-desc">{latestWriting.summary}</p>
              )}
            </div>
          </li>
        )}
      </ul>

      <div class="activity-footer">
        <a href="/counting-lives/" class="activity-viewall">All chapters →</a>
        <a href="/tda/" class="activity-viewall">All papers →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ══ Hero ══════════════════════════════════════════════════════════════════ */

  .hero {
    background-color: var(--color-cl-cream);
    min-height: 60vh;
    display: flex;
    align-items: center;
    width: 100%;
  }

  .hero__inner {
    padding-top: var(--space-14);
    padding-bottom: var(--space-14);
  }

  .hero__tagline {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    line-height: var(--leading-tight);
    color: var(--color-cl-charcoal);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-7) 0;
    max-width: 18ch;
  }

  .hero__subtitle {
    font-family: var(--font-body);
    font-size: var(--text-xl);
    line-height: var(--leading-relaxed);
    color: var(--color-cl-charcoal);
    max-width: 55ch;
    margin: 0;
  }

  @media (max-width: 640px) {
    .hero__tagline {
      font-size: var(--text-4xl);
    }
    .hero__subtitle {
      font-size: var(--text-lg);
    }
    .hero__inner {
      padding-top: var(--space-11);
      padding-bottom: var(--space-11);
    }
  }

  /* ══ Projects section ═══════════════════════════════════════════════════════ */

  .projects-section {
    background-color: var(--color-neutral-bg);
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
  }

  .projects-inner {
    /* .container-viz applies max-width + gutter; no extra styles needed */
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }

  @media (max-width: 640px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ══ Project cards ══════════════════════════════════════════════════════════ */

  .project-card {
    background-color: var(--color-neutral-surface);
    border: 1px solid var(--color-neutral-border);
    border-radius: var(--radius-lg);
    padding: var(--space-9);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    transition: box-shadow 0.2s ease;
  }

  .project-card:hover {
    box-shadow: var(--shadow-md);
  }

  .project-card__title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    line-height: var(--leading-snug);
    margin: 0;
  }

  .project-card--cl .project-card__title {
    color: var(--color-cl-red);
  }

  .project-card--tda .project-card__title {
    color: var(--color-tda-teal);
  }

  .project-card__desc {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-neutral-body);
    margin: 0;
    flex: 1;
  }

  /* ── Link buttons ─────────────────────────────────────────────────────── */

  .project-card__link {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-md);
    border: 2px solid;
    transition: background-color 0.15s ease, color 0.15s ease;
    align-self: flex-start;
  }

  .card-link--cl {
    color: var(--color-cl-red);
    border-color: var(--color-cl-red);
  }

  .card-link--cl:hover,
  .card-link--cl:focus-visible {
    background-color: var(--color-cl-red);
    color: var(--color-cl-cream);
    outline: 2px solid var(--color-cl-red);
    outline-offset: 2px;
  }

  .card-link--tda {
    color: var(--color-tda-teal);
    border-color: var(--color-tda-teal);
  }

  .card-link--tda:hover,
  .card-link--tda:focus-visible {
    background-color: var(--color-tda-teal);
    color: var(--color-neutral-surface);
    outline: 2px solid var(--color-tda-teal);
    outline-offset: 2px;
  }

  /* ══ Recent activity ═══════════════════════════════════════════════════════ */

  .activity-section {
    background-color: var(--color-neutral-subtle);
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
  }

  .activity-heading {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--color-neutral-body);
    margin: 0 0 var(--space-8) 0;
  }

  .activity-list {
    list-style: none;
    margin: 0 0 var(--space-8) 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .activity-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    background-color: var(--color-neutral-surface);
    border: 1px solid var(--color-neutral-border);
    border-radius: var(--radius-md);
  }

  .activity-badge {
    flex-shrink: 0;
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    margin-top: 0.2em;
  }

  .activity-badge--chapter {
    background-color: var(--color-cl-cream);
    color: var(--color-cl-red);
    border: 1px solid var(--color-cl-red-light);
  }

  .activity-badge--paper {
    background-color: var(--color-tda-warm-grey);
    color: var(--color-tda-teal);
    border: 1px solid var(--color-tda-teal-light);
  }

  .activity-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .activity-title {
    font-family: var(--font-ui);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-neutral-body);
    text-decoration: none;
  }

  .activity-title:hover,
  .activity-title:focus-visible {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .activity-desc {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-neutral-muted);
    margin: 0;
    line-height: var(--leading-snug);
  }

  .activity-footer {
    display: flex;
    gap: var(--space-6);
  }

  .activity-viewall {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-neutral-muted);
    text-decoration: none;
  }

  .activity-viewall:hover,
  .activity-viewall:focus-visible {
    color: var(--color-neutral-body);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Utility: visually hidden but accessible ──────────────────────────── */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

