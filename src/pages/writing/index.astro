---
/**
 * index.astro — Task 2.5 — Agent_Design_Templates
 * Writing section hub: all posts (essays + notes) in reverse chronological order.
 *
 * Tag filtering: tag pills link to static per-tag pages at /writing/tags/{tag}/
 * (no-JS path). JS can enhance with ?tag= URL param client-side filtering.
 */

import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

type EssayEntry = CollectionEntry<'essays'> & { variant: 'essay' };
type NoteEntry  = CollectionEntry<'notes'>  & { variant: 'note'  };
type AnyEntry   = EssayEntry | NoteEntry;

const [essays, notes] = await Promise.all([
  getCollection('essays', ({ data }) => !data.draft),
  getCollection('notes',  ({ data }) => !data.draft),
]);

const allPosts: AnyEntry[] = [
  ...essays.map((e): EssayEntry => ({ ...e, variant: 'essay' })),
  ...notes.map((e): NoteEntry  => ({ ...e, variant: 'note'  })),
].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Unique tags, sorted alphabetically
const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))].sort();

const formatDate = (d: Date) =>
  new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }).format(d);

const postHref = (entry: AnyEntry) =>
  `/writing/${entry.variant === 'essay' ? 'essays' : 'notes'}/${entry.id}/`;

const summary = (entry: AnyEntry): string | undefined =>
  'summary' in entry.data ? (entry.data as { summary?: string }).summary : undefined;
---

<BaseLayout
  title="Writing"
  description="Essays and notes on poverty measurement, topological data analysis, and research methodology."
  section="writing"
>
  <div class="container-prose">
    <header class="writing-header">
      <h1>Writing</h1>
      <p class="writing-lede">
        Essays and notes on poverty measurement, topological data analysis, and
        research methodology.
      </p>
    </header>

    {allTags.length > 0 && (
      <nav class="tag-cloud" aria-label="Filter posts by tag">
        <span class="tag-cloud-label" aria-hidden="true">Filter:</span>
        <a href="/writing/" class="tag-pill tag-pill--active">All</a>
        {allTags.map((tag) => (
          <a href={`/writing/tags/${tag}/`} class="tag-pill">{tag}</a>
        ))}
      </nav>
    )}

    {allPosts.length === 0 ? (
      <p class="no-posts">No posts yet — check back soon.</p>
    ) : (
      <ol class="posts-list">
        {allPosts.map((entry) => {
          const entrySummary = summary(entry);
          return (
            <li class="post-item">
              <article>
                <div class="post-item-meta">
                  <time datetime={entry.data.date.toISOString()}>
                    {formatDate(entry.data.date)}
                  </time>
                  <span
                    class:list={['variant-badge', `variant-badge--${entry.variant}`]}
                    aria-label={`Post type: ${entry.variant === 'essay' ? 'Essay' : 'Note'}`}
                  >
                    {entry.variant === 'essay' ? 'Essay' : 'Note'}
                  </span>
                </div>
                <h2 class="post-item-title">
                  <a href={postHref(entry)}>{entry.data.title}</a>
                </h2>
                {entrySummary && (
                  <p class="post-item-summary">{entrySummary}</p>
                )}
                {entry.data.tags.length > 0 && (
                  <ul class="post-item-tags" aria-label="Tags">
                    {entry.data.tags.map((tag) => (
                      <li>
                        <a href={`/writing/tags/${tag}/`} class="tag-pill tag-pill--sm">
                          {tag}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </article>
            </li>
          );
        })}
      </ol>
    )}
  </div>
</BaseLayout>

<style>
  /* ── Page header ─────────────────────────────────────────────────────────── */
  .writing-header {
    padding-top: var(--space-9);
    padding-bottom: var(--space-7);
    border-bottom: 1px solid var(--color-neutral-border);
    margin-bottom: var(--space-8);
  }

  .writing-header h1 {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--color-neutral-body);
    margin-top: 0;
    margin-bottom: var(--space-4);
  }

  .writing-lede {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-neutral-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  /* ── Tag cloud ────────────────────────────────────────────────────────────── */
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }

  .tag-cloud-label {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--color-neutral-muted);
    margin-right: var(--space-2);
  }

  /* ── Tag pills ────────────────────────────────────────────────────────────── */
  .tag-pill {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: lowercase;
    text-decoration: none;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-neutral-border);
    background: var(--color-neutral-surface);
    color: var(--color-neutral-muted);
    transition: background 150ms ease, color 150ms ease, border-color 150ms ease;
  }

  .tag-pill:hover,
  .tag-pill--active {
    background: var(--color-neutral-subtle);
    color: var(--color-neutral-body);
    border-color: var(--color-neutral-muted);
  }

  .tag-pill--sm {
    font-size: calc(var(--text-xs) * 0.9);
    padding: 0.1rem var(--space-2);
  }

  /* ── Posts list ──────────────────────────────────────────────────────────── */
  .posts-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .post-item {
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-neutral-border);
  }

  .post-item:last-child {
    border-bottom: none;
    padding-bottom: var(--space-10);
  }

  /* ── Variant badge ───────────────────────────────────────────────────────── */
  .post-item-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--color-neutral-muted);
    margin-bottom: var(--space-2);
  }

  .variant-badge {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 0.125rem var(--space-2);
    border-radius: var(--radius-sm);
  }

  .variant-badge--essay {
    background: var(--color-cl-cream);
    color: var(--color-cl-red);
    border: 1px solid var(--color-cl-red-light);
  }

  .variant-badge--note {
    background: var(--color-tda-warm-grey);
    color: var(--color-tda-teal);
    border: 1px solid var(--color-tda-teal-light);
  }

  /* ── Post item heading ───────────────────────────────────────────────────── */
  .post-item-title {
    font-family: var(--font-body);
    font-size: var(--text-xl);
    font-weight: 700;
    line-height: var(--leading-snug);
    margin-top: 0;
    margin-bottom: var(--space-3);
  }

  .post-item-title a {
    color: var(--color-neutral-body);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .post-item-title a:hover {
    color: var(--color-tda-teal);
  }

  /* ── Summary ─────────────────────────────────────────────────────────────── */
  .post-item-summary {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-neutral-muted);
    line-height: var(--leading-relaxed);
    margin-top: 0;
    margin-bottom: var(--space-4);
  }

  /* ── Inline tag list on posts ────────────────────────────────────────────── */
  .post-item-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* ── No posts placeholder ────────────────────────────────────────────────── */
  .no-posts {
    font-family: var(--font-ui);
    color: var(--color-neutral-muted);
    padding: var(--space-10) 0;
    text-align: center;
  }
</style>

