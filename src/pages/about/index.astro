---
/**
 * about/index.astro — About section — Task 2.8 — Agent_Design_Templates
 * Bio, web CV, contact & links, media kit.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="Academic biography, curriculum vitae, research interests, and contact information."
  section="about"
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Stephen Dorling",
      "url": "https://zktheory.org/about/",
      "identifier": "https://orcid.org/0009-0005-1387-7279",
      "sameAs": ["https://orcid.org/0009-0005-1387-7279"],
      "affiliation": {
        "@type": "Organization",
        "name": "The Open University, UK"
      },
      "knowsAbout": ["Topological Data Analysis", "Poverty Measurement", "Welfare Policy"]
    })} />
  </Fragment>

  <div class="about-page">

    <!-- ══ Bio ═══════════════════════════════════════════════════════════════ -->
    <section class="about-section" aria-labelledby="about-heading">
      <div class="container-prose">
        <h1 id="about-heading" class="about-h1">About</h1>

        <!-- Positionality statement — needs real content from author -->
        <div class="positionality-block" aria-label="Positionality statement">
          <p class="positionality-label">Positionality statement</p>
          <p>
            <!-- TODO: Replace the following placeholder with real positionality statement (~100 words) -->
            My research sits at the intersection of poverty measurement, welfare-state history,
            and topological data analysis. I am a [<em>position</em>] at <em>The Open University, UK</em>,
            working within the [<em>department</em>]. I came to this project through a long-standing
            interest in how quantitative social science translates lived experience into data — and
            who bears the cost of that translation. The subjects of poverty measurement are not
            abstract. I am conscious that the analytical distance this work requires is a privilege,
            and I have tried throughout to hold that tension honestly.
          </p>
        </div>

        <!-- Research interests -->
        <div class="research-interests">
          <h2 class="about-h2">Research Interests</h2>
          <ul class="interests-grid">
            <li><a href="/tda/">Topological Data Analysis</a></li>
            <li><a href="/counting-lives/">History of Poverty Measurement</a></li>
            <li><a href="/tda/">Longitudinal Labour-Market Trajectories</a></li>
            <li><a href="/counting-lives/">Welfare State Comparative Analysis</a></li>
            <li><a href="/learn/">Mathematics for Social Scientists</a></li>
            <li><a href="/counting-lives/">Political Economy of Statistics</a></li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ══ CV ════════════════════════════════════════════════════════════════ -->
    <section class="about-section about-section--alt" aria-labelledby="cv-heading">
      <div class="container-prose">
        <div class="cv-header">
          <h2 class="about-h2" id="cv-heading">Curriculum Vitae</h2>
          {/* TODO: Replace href with real PDF path when file is added to /public/ */}
          <a href="/cv.pdf" class="cv-download" aria-label="Download CV as PDF (file not yet available)">
            Download PDF ↓
          </a>
        </div>

        <!-- Education -->
        <section class="cv-section" aria-labelledby="cv-education">
          <h3 class="cv-section-heading" id="cv-education">Education</h3>
          <dl class="cv-list">
            <div class="cv-entry">
              <dt class="cv-entry__meta">
                <!-- TODO: replace years -->
                <span class="cv-entry__year">201x–201x</span>
                <span class="cv-entry__inst">[Institution Name]</span>
              </dt>
              <dd class="cv-entry__detail">
                PhD, [Discipline] — "<em>[Thesis title placeholder]</em>"
              </dd>
            </div>
            <div class="cv-entry">
              <dt class="cv-entry__meta">
                <span class="cv-entry__year">200x–201x</span>
                <span class="cv-entry__inst">[Institution Name]</span>
              </dt>
              <dd class="cv-entry__detail">
                MA/MSc, [Discipline] — Distinction
              </dd>
            </div>
          </dl>
        </section>

        <!-- Publications -->
        <section class="cv-section" aria-labelledby="cv-publications">
          <h3 class="cv-section-heading" id="cv-publications">Publications</h3>
          <ul class="cv-list--plain">
            <li>
              Book manuscript in progress: see <a href="/counting-lives/">Counting Lives</a>
            </li>
            <li>
              TDA paper series (10 papers, stages 0–3): see <a href="/tda/">Research Programme</a>
            </li>
          </ul>
        </section>

        <!-- Presentations -->
        <section class="cv-section" aria-labelledby="cv-presentations">
          <h3 class="cv-section-heading" id="cv-presentations">Presentations</h3>
          <dl class="cv-list">
            <div class="cv-entry">
              <dt class="cv-entry__meta">
                <span class="cv-entry__year">202x</span>
                <span class="cv-entry__inst">[Conference Name]</span>
              </dt>
              <dd class="cv-entry__detail">
                "[Presentation title placeholder]"
              </dd>
            </div>
            <div class="cv-entry">
              <dt class="cv-entry__meta">
                <span class="cv-entry__year">202x</span>
                <span class="cv-entry__inst">[Conference Name]</span>
              </dt>
              <dd class="cv-entry__detail">
                "[Presentation title placeholder]"
              </dd>
            </div>
          </dl>
        </section>

        <!-- Teaching -->
        <section class="cv-section" aria-labelledby="cv-teaching">
          <h3 class="cv-section-heading" id="cv-teaching">Teaching</h3>
          <ul class="cv-list--plain">
            <li>
              Learning paths and open modules: see <a href="/learn/">Learning</a>
            </li>
          </ul>
        </section>
      </div>
    </section>

    <!-- ══ Contact & links ════════════════════════════════════════════════ -->
    <section class="about-section" aria-labelledby="contact-heading">
      <div class="container-prose">
        <h2 class="about-h2" id="contact-heading">Contact &amp; Links</h2>
        <ul class="contact-list">
          <li>
            <span class="contact-label">Email</span>
            {/* TODO: Replace with real email address */}
            <a href="mailto:name@institution.ac.uk">name@institution.ac.uk</a>
          </li>
          <li>
            <span class="contact-label">ORCID</span>
            <a href="https://orcid.org/0009-0005-1387-7279" rel="me noopener noreferrer">0009-0005-1387-7279</a>
          </li>
          <li>
            <span class="contact-label">GitHub</span>
            {/* TODO: Replace href with real GitHub profile URL */}
            <a href="/todo/github" rel="noopener noreferrer">GitHub profile (link pending)</a>
          </li>
          <li>
            <span class="contact-label">Google Scholar</span>
            {/* TODO: Replace href with real Google Scholar profile URL */}
            <a href="/todo/scholar" rel="noopener noreferrer">Google Scholar profile (link pending)</a>
          </li>
          <li>
            <span class="contact-label">Institutional page</span>
            <a href="https://www.open.ac.uk" rel="noopener noreferrer">The Open University, UK</a>
          </li>
        </ul>
      </div>
    </section>

    <!-- ══ Media kit ═════════════════════════════════════════════════════ -->
    <section class="about-section about-section--alt" aria-labelledby="mediakit-heading">
      <div class="container-prose">
        <h2 class="about-h2" id="mediakit-heading">Media Kit</h2>

        <!-- Headshot -->
        <div class="headshot-placeholder"
          role="img"
          aria-label="Headshot placeholder — replace with real photograph">
          <span class="headshot-placeholder__label">Headshot<br />(placeholder)</span>
        </div>

        <!-- Short bio -->
        <section class="bio-block" aria-labelledby="bio-short-heading">
          <h3 class="bio-block__heading" id="bio-short-heading">
            Short biography <span class="bio-block__wordcount">(~150 words)</span>
          </h3>
          <blockquote class="bio-block__text">
            <!-- TODO: Replace with real 150-word short bio for media / event programmes -->
            [Author name] is a [title] at [institution], where they research the history of poverty
            measurement and apply topological data analysis to longitudinal panel data. Their book,
            <em>Counting Lives</em>, examines how poverty lines have functioned as political
            instruments from Rowntree's York surveys to contemporary multidimensional indices.
            Alongside this historical project, they lead a programme of ten linked papers applying
            Mapper, persistent homology, and graph-neural-network methods to UK household panel data
            from BHPS and Understanding Society. Their work appears in [journal placeholders] and has
            been presented at [conference placeholders]. They are committed to open research and
            publish all data, code, and intermediate results at zktheory.org. [Add institutional
            affiliations, fellowships, or awards here. Target: 150 words total.]
          </blockquote>
        </section>

        <!-- Long bio -->
        <section class="bio-block" aria-labelledby="bio-long-heading">
          <h3 class="bio-block__heading" id="bio-long-heading">
            Long biography <span class="bio-block__wordcount">(~500 words)</span>
          </h3>
          <blockquote class="bio-block__text">
            <!-- TODO: Replace with real 500-word long bio for press / grant applications -->
            <p>
              [Author name] is a [title] at [institution], working at the intersection of historical
              sociology, welfare-state studies, and mathematical data analysis. Their current
              research programme comprises two intertwined projects: a book-length historical
              investigation into the politics of poverty measurement, and a programme of ten linked
              papers applying topological data analysis to UK longitudinal panel data.
            </p>
            <p>
              The book project, <em>Counting Lives</em>, traces how poverty lines have functioned
              as political instruments across two centuries of measurement practice — from Quetelet's
              statistical imagination and Rowntree's dietary surveys through the post-war Beveridge
              settlement, the rediscovery of relative poverty in the 1960s, and the turn to
              multidimensional indices in the 1990s and 2000s. The book argues that the poverty line
              was never a neutral scientific instrument but always a site of political contestation
              dressed in the language of social science. [Expand: 2–3 more sentences on argument
              and methodology.]
            </p>
            <p>
              The TDA research programme applies methods drawn from algebraic topology —
              particularly the Mapper algorithm and persistent homology — to employment and poverty
              trajectories drawn from the British Household Panel Survey and its successor,
              Understanding Society. These methods reveal the topological shape of career
              trajectories: the clusters, flares, and loops that conventional sequence-analysis
              methods smooth away. [Expand: 2–3 sentences on key findings and contributions.]
            </p>
            <p>
              [Author name] received their [degree] from [institution] in [year], and their [prior
              degree] from [institution] in [year]. They have held positions at [prior
              institution(s)] and have received funding from [funders]. Their work has been
              published in [journals] and presented at [conferences]. [Add: editorial roles,
              committee memberships, public engagement. Target: 500 words total.]
            </p>
          </blockquote>
        </section>
      </div>
    </section>

  </div>{/* .about-page */}
</BaseLayout>

<style>
  /* ══ Page shell ═══════════════════════════════════════════════════════════ */

  .about-page {
    padding-bottom: var(--space-14);
  }

  /* ══ Section alternating backgrounds ════════════════════════════════════ */

  .about-section {
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
  }

  .about-section--alt {
    background-color: var(--color-neutral-subtle);
  }

  /* ══ Headings ════════════════════════════════════════════════════════════ */

  .about-h1 {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    line-height: var(--leading-tight);
    color: var(--color-neutral-body);
    margin: 0 0 var(--space-9) 0;
  }

  .about-h2 {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    line-height: var(--leading-snug);
    color: var(--color-neutral-body);
    margin: 0 0 var(--space-7) 0;
  }

  /* ══ Positionality block ═════════════════════════════════════════════════ */

  .positionality-block {
    border-left: 3px solid var(--color-cl-ochre);
    padding-left: var(--space-6);
    margin-bottom: var(--space-10);
  }

  .positionality-label {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-cl-red); /* was cl-ochre (3.31:1); cl-red gives 6.6:1 on neutral-bg */
    margin: 0 0 var(--space-3) 0;
  }

  .positionality-block p:last-child {
    margin: 0;
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-neutral-body);
  }

  /* ══ Research interests grid ═════════════════════════════════════════════ */

  .research-interests {
    margin-top: var(--space-10);
  }

  .interests-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3) var(--space-8);
  }

  .interests-grid li {
    font-family: var(--font-ui);
    font-size: var(--text-base);
  }

  .interests-grid a {
    color: var(--color-neutral-body);
    text-decoration: none;
    border-bottom: 1px solid var(--color-neutral-border);
    padding-bottom: 1px;
  }

  .interests-grid a:hover,
  .interests-grid a:focus-visible {
    color: var(--color-tda-teal);
    border-bottom-color: var(--color-tda-teal);
    outline: none;
  }

  @media (max-width: 640px) {
    .interests-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ══ CV ══════════════════════════════════════════════════════════════════ */

  .cv-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
    flex-wrap: wrap;
  }

  .cv-header .about-h2 {
    margin-bottom: 0;
  }

  .cv-download {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-neutral-muted);
    text-decoration: none;
    border: 1px solid var(--color-neutral-border);
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-4);
    white-space: nowrap;
  }

  .cv-download:hover,
  .cv-download:focus-visible {
    color: var(--color-neutral-body);
    border-color: var(--color-neutral-body);
    outline: 2px solid var(--color-neutral-body);
    outline-offset: 2px;
  }

  .cv-section {
    margin-bottom: var(--space-9);
  }

  .cv-section-heading {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-neutral-muted);
    margin: 0 0 var(--space-5) 0;
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-neutral-border);
  }

  /* DL-based CV entries */
  .cv-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    margin: 0;
    padding: 0;
  }

  .cv-entry {
    display: grid;
    grid-template-columns: 14rem 1fr;
    gap: var(--space-4);
    align-items: baseline;
  }

  @media (max-width: 640px) {
    .cv-entry {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }

  .cv-entry__meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .cv-entry__year {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-neutral-muted);
  }

  .cv-entry__inst {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-neutral-body);
  }

  .cv-entry__detail {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-neutral-body);
    margin: 0;
    line-height: var(--leading-relaxed);
  }

  /* Plain list variant */
  .cv-list--plain {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cv-list--plain li {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-neutral-body);
    line-height: var(--leading-relaxed);
  }

  .cv-list--plain a,
  .cv-entry__detail a,
  .positionality-block a {
    color: var(--color-tda-teal);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .cv-list--plain a:hover,
  .cv-entry__detail a:hover {
    color: var(--color-tda-teal-light);
  }

  /* ══ Contact ═════════════════════════════════════════════════════════════ */

  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact-list li {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-base);
  }

  .contact-label {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-neutral-muted);
    min-width: 10rem;
    flex-shrink: 0;
  }

  .contact-list a {
    color: var(--color-tda-teal);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .contact-list a:hover {
    color: var(--color-tda-teal-light);
  }

  @media (max-width: 640px) {
    .contact-list li {
      flex-direction: column;
      gap: var(--space-1);
    }
    .contact-label {
      min-width: unset;
    }
  }

  /* ══ Media kit ═══════════════════════════════════════════════════════════ */

  /* Headshot placeholder */
  .headshot-placeholder {
    width: 180px;
    height: 180px;
    background-color: var(--color-neutral-subtle);
    border: 2px dashed var(--color-neutral-border);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    margin-bottom: var(--space-9);
  }

  .headshot-placeholder__label {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--color-neutral-muted);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    line-height: var(--leading-snug);
  }

  /* Bio blocks */
  .bio-block {
    margin-bottom: var(--space-10);
  }

  .bio-block__heading {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-neutral-muted);
    margin: 0 0 var(--space-4) 0;
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-neutral-border);
  }

  .bio-block__wordcount {
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
    font-size: var(--text-xs);
    color: var(--color-neutral-muted);
  }

  .bio-block__text {
    margin: 0;
    padding: var(--space-5) var(--space-6);
    border-left: 3px solid var(--color-neutral-border);
    background-color: var(--color-neutral-bg);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .bio-block__text p {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-neutral-body);
    margin: 0 0 var(--space-4) 0;
  }

  .bio-block__text p:last-child {
    margin-bottom: 0;
  }
</style>

