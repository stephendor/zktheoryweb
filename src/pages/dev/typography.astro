---
// Development artefact — Task 1.4 — Agent_Design_System
// Updated Task 1.5 — Agent_Design_Templates: migrated to BaseLayout
// Updated Task 1.7 — Agent_Schema_Platform: KaTeX math specimens added
import BaseLayout from '@layouts/BaseLayout.astro';
import katex from 'katex';

if (import.meta.env.PROD) {
  return new Response(null, { status: 404 });
}

const mathInline = katex.renderToString('f(x) = \\mu + \\sigma z', { throwOnError: false, output: 'htmlAndMathml' });
const mathDisplay = katex.renderToString('\\sum_{i=1}^{n} x_i = n\\bar{x}', { throwOnError: false, output: 'htmlAndMathml', displayMode: true });
---

<BaseLayout title="Typography Specimens">

<style>
      /* Page-level styles — all design values via tokens */
      /* Box-sizing reset and base body styles are now handled by BaseLayout */

      .dev-banner {
        position: sticky;
        top: 0;
        z-index: 100;
        background: #7c3aed;
        color: #fff;
        text-align: center;
        padding: var(--space-2) var(--space-4);
        font-family: var(--font-ui);
        font-size: var(--text-sm);
        font-weight: 600;
        letter-spacing: var(--tracking-wide);
        text-transform: uppercase;
      }

      .page-wrap {
        max-width: 900px;
        margin: 0 auto;
        padding: var(--space-9) var(--space-7);
      }

      .page-title {
        font-family: var(--font-ui);
        font-size: var(--text-sm);
        font-weight: 600;
        letter-spacing: var(--tracking-widest);
        text-transform: uppercase;
        color: var(--color-neutral-muted);
        margin-bottom: var(--space-9);
        margin-top: var(--space-7);
        padding-bottom: var(--space-3);
        border-bottom: 1px solid var(--color-neutral-border);
      }

      /* Section scaffolding */
      .section {
        margin-bottom: var(--space-12);
      }

      .section-label {
        font-family: var(--font-ui);
        font-size: var(--text-xs);
        font-weight: 600;
        letter-spacing: var(--tracking-widest);
        text-transform: uppercase;
        color: var(--color-neutral-muted);
        margin-bottom: var(--space-6);
        padding-bottom: var(--space-2);
        border-bottom: 1px solid var(--color-neutral-border);
      }

      .specimen-row {
        display: flex;
        align-items: baseline;
        gap: var(--space-6);
        margin-bottom: var(--space-4);
        flex-wrap: wrap;
      }

      .token-tag {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--color-neutral-muted);
        background: var(--color-tda-warm-grey);
        padding: 2px var(--space-2);
        border-radius: var(--radius-sm);
        white-space: nowrap;
        flex-shrink: 0;
        min-width: 9rem;
      }

      .divider {
        border: none;
        border-top: 1px solid var(--color-neutral-border);
        margin: var(--space-10) 0;
      }

      /* Colour swatch helpers */
      .swatch-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: var(--space-4);
      }
      .swatch {
        padding: var(--space-6) var(--space-5);
        border-radius: var(--radius-md);
        border: 1px solid var(--color-neutral-border);
      }
      .swatch .swatch-label {
        font-family: var(--font-ui);
        font-size: var(--text-sm);
        font-weight: 500;
      }
      .swatch .swatch-sub {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        opacity: 0.7;
        margin-top: var(--space-1);
      }
</style>
    <div class="dev-banner">Development Preview — Not for Production</div>

    <div class="page-wrap">
      <p class="page-title">Typography Specimens — zktheory.org · Task 1.4 Review Artefact</p>

      <!-- ═══ 1. DISPLAY FONT — PLAYFAIR DISPLAY ═══════════════════════════ -->
      <section class="section">
        <p class="section-label">1. Display Serif — Playfair Display</p>

        <div style="margin-bottom: var(--space-7);">
          <h1 style="font-family: var(--font-display); font-size: var(--text-5xl); font-weight: 700; line-height: var(--leading-tight); letter-spacing: var(--tracking-tight); color: var(--color-neutral-body);">
            Counting Lives, Mapping Spaces
          </h1>
          <p class="token-tag" style="margin-top: var(--space-2);">font-display · text-5xl · weight-700 · leading-tight</p>
        </div>

        <div style="margin-bottom: var(--space-7);">
          <h2 style="font-family: var(--font-display); font-size: var(--text-4xl); font-weight: 400; line-height: var(--leading-tight); color: var(--color-tda-teal);">
            Topological Data Analysis of Poverty
          </h2>
          <p class="token-tag" style="margin-top: var(--space-2);">font-display · text-4xl · weight-400 · tda-teal</p>
        </div>

        <div style="margin-bottom: var(--space-7);">
          <p style="font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 700; font-style: italic; line-height: var(--leading-snug); color: var(--color-cl-red);">
            The Archival Imperative
          </p>
          <p class="token-tag" style="margin-top: var(--space-2);">font-display · text-3xl · weight-700 · italic · cl-red</p>
        </div>
      </section>

      <hr class="divider" />

      <!-- ═══ 2. BODY SERIF — SOURCE SERIF 4 ═══════════════════════════════ -->
      <section class="section">
        <p class="section-label">2. Body Serif — Source Serif 4</p>

        <div style="margin-bottom: var(--space-7);">
          <h3 style="font-family: var(--font-body); font-size: var(--text-2xl); font-weight: 700; line-height: var(--leading-snug); margin-bottom: var(--space-4);">
            Article Heading — Weight 700
          </h3>
          <p class="token-tag">font-body · text-2xl · weight-700</p>
        </div>

        <div style="max-width: var(--measure-prose); margin-bottom: var(--space-7);">
          <p style="font-family: var(--font-body); font-size: var(--text-base); font-weight: 400; line-height: var(--leading-relaxed); margin-bottom: var(--space-4);">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor
            incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud
            exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure
            dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.
            Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt
            mollit anim id est laborum. Pellentesque habitant morbi tristique senectus et netus et
            malesuada fames ac turpis egestas.
          </p>
          <p class="token-tag">font-body · text-base · weight-400 · leading-relaxed · max-width: measure-prose (65ch)</p>
        </div>

        <div style="max-width: var(--measure-prose); margin-bottom: var(--space-7);">
          <p style="font-family: var(--font-body); font-size: var(--text-base); font-style: italic; font-weight: 400; line-height: var(--leading-relaxed);">
            <em>Italic body text: Lorem ipsum dolor sit amet, consectetur adipiscing elit. Rendered
            using Source Serif 4 400italic. Harmonises with KaTeX Computer Modern math output
            placed inline within prose.</em>
          </p>
          <p class="token-tag" style="margin-top: var(--space-2);">font-body · text-base · italic · weight-400</p>
        </div>

        <!-- Weight showcase -->
        <div style="display: flex; flex-direction: column; gap: var(--space-3);">
          <div class="specimen-row">
            <span class="token-tag">weight-400 (regular)</span>
            <span style="font-family: var(--font-body); font-size: var(--text-lg); font-weight: 400;">Source Serif 4 — Regular</span>
          </div>
          <div class="specimen-row">
            <span class="token-tag">weight-400 italic</span>
            <span style="font-family: var(--font-body); font-size: var(--text-lg); font-weight: 400; font-style: italic;">Source Serif 4 — Italic</span>
          </div>
          <div class="specimen-row">
            <span class="token-tag">weight-700 (bold)</span>
            <span style="font-family: var(--font-body); font-size: var(--text-lg); font-weight: 700;">Source Serif 4 — Bold</span>
          </div>
        </div>
      </section>

      <hr class="divider" />

      <!-- ═══ 3. UI SANS — INSTRUMENT SANS ════════════════════════════════ -->
      <section class="section">
        <p class="section-label">3. UI Sans-Serif — Instrument Sans</p>

        <div style="display: flex; flex-direction: column; gap: var(--space-4); margin-bottom: var(--space-7);">
          <div class="specimen-row">
            <span class="token-tag">weight-400 (regular)</span>
            <span style="font-family: var(--font-ui); font-size: var(--text-base); font-weight: 400;">Navigation item — regular label</span>
          </div>
          <div class="specimen-row">
            <span class="token-tag">weight-500 (medium)</span>
            <span style="font-family: var(--font-ui); font-size: var(--text-base); font-weight: 500;">Navigation item — medium label</span>
          </div>
          <div class="specimen-row">
            <span class="token-tag">weight-600 (semibold)</span>
            <span style="font-family: var(--font-ui); font-size: var(--text-base); font-weight: 600;">Navigation item — semibold label</span>
          </div>
        </div>

        <!-- Button specimens -->
        <div style="display: flex; gap: var(--space-4); flex-wrap: wrap; align-items: center;">
          <button style="font-family: var(--font-ui); font-size: var(--text-sm); font-weight: 600; letter-spacing: var(--tracking-wide); background: var(--color-tda-teal); color: white; border: none; border-radius: var(--radius-md); padding: var(--space-3) var(--space-6); cursor: pointer;">
            Primary Button
          </button>
          <button style="font-family: var(--font-ui); font-size: var(--text-sm); font-weight: 600; letter-spacing: var(--tracking-wide); background: transparent; color: var(--color-tda-teal); border: 2px solid var(--color-tda-teal); border-radius: var(--radius-md); padding: var(--space-3) var(--space-6); cursor: pointer;">
            Outline Button
          </button>
          <span style="font-family: var(--font-ui); font-size: var(--text-xs); font-weight: 500; letter-spacing: var(--tracking-wider); text-transform: uppercase; color: var(--color-neutral-muted);">
            UI Label / Caption
          </span>
        </div>
      </section>

      <hr class="divider" />

      <!-- ═══ 4. MONOSPACE — JETBRAINS MONO ════════════════════════════════ -->
      <section class="section">
        <p class="section-label">4. Monospace — JetBrains Mono</p>

        <div style="background: var(--color-cl-charcoal); border-radius: var(--radius-md); padding: var(--space-6) var(--space-7); margin-bottom: var(--space-4);">
          <pre style="font-family: var(--font-mono); font-size: var(--text-sm); line-height: var(--leading-relaxed); color: #e8e4dc; white-space: pre; overflow-x: auto;"><code>// JetBrains Mono — weight-400, text-sm
const persistenceHomology = (filtration: Filtration) =&gt; &#123;
  const diagram = compute(filtration);
  return diagram.pairs.map(([birth, death]) =&gt; &#123;
    return &#123; birth, death, persistence: death - birth &#125;;
  &#125;);
&#125;;</code></pre>
        </div>
        <p class="token-tag">font-mono · text-sm · weight-400 · leading-relaxed</p>
      </section>

      <hr class="divider" />

      <!-- ═══ 5. FULL TYPE SCALE ════════════════════════════════════════════ -->
      <section class="section">
        <p class="section-label">5. Full Type Scale — text-xs → text-6xl</p>

        <div style="display: flex; flex-direction: column; gap: var(--space-5);">
          <div class="specimen-row">
            <span class="token-tag">--text-xs · 0.75rem</span>
            <span style="font-family: var(--font-body); font-size: var(--text-xs);">The quick brown fox jumps over the lazy dog</span>
          </div>
          <div class="specimen-row">
            <span class="token-tag">--text-sm · 0.875rem</span>
            <span style="font-family: var(--font-body); font-size: var(--text-sm);">The quick brown fox jumps over the lazy dog</span>
          </div>
          <div class="specimen-row">
            <span class="token-tag">--text-base · 1rem</span>
            <span style="font-family: var(--font-body); font-size: var(--text-base);">The quick brown fox jumps over the lazy dog</span>
          </div>
          <div class="specimen-row">
            <span class="token-tag">--text-lg · 1.125rem</span>
            <span style="font-family: var(--font-body); font-size: var(--text-lg);">The quick brown fox jumps over the lazy dog</span>
          </div>
          <div class="specimen-row">
            <span class="token-tag">--text-xl · 1.25rem</span>
            <span style="font-family: var(--font-body); font-size: var(--text-xl);">The quick brown fox jumps over the lazy dog</span>
          </div>
          <div class="specimen-row">
            <span class="token-tag">--text-2xl · 1.5rem</span>
            <span style="font-family: var(--font-body); font-size: var(--text-2xl);">The quick brown fox jumps</span>
          </div>
          <div class="specimen-row">
            <span class="token-tag">--text-3xl · 1.875rem</span>
            <span style="font-family: var(--font-display); font-size: var(--text-3xl);">Topological Analysis</span>
          </div>
          <div class="specimen-row">
            <span class="token-tag">--text-4xl · 2.25rem</span>
            <span style="font-family: var(--font-display); font-size: var(--text-4xl);">Counting Lives</span>
          </div>
          <div class="specimen-row">
            <span class="token-tag">--text-5xl · 3rem</span>
            <span style="font-family: var(--font-display); font-size: var(--text-5xl);">zktheory</span>
          </div>
          <div class="specimen-row">
            <span class="token-tag">--text-6xl · 3.75rem</span>
            <span style="font-family: var(--font-display); font-size: var(--text-6xl);">zktheory</span>
          </div>
        </div>
      </section>

      <hr class="divider" />

      <!-- ═══ 6. COLOUR PAIRINGS ════════════════════════════════════════════ -->
      <section class="section">
        <p class="section-label">6. Colour Pairings</p>

        <div class="swatch-grid">
          <!-- Body text on neutral-bg -->
          <div class="swatch" style="background: var(--color-neutral-bg);">
            <p class="swatch-label" style="font-family: var(--font-body); color: var(--color-neutral-body);">Body text on neutral-bg</p>
            <p class="swatch-sub" style="color: var(--color-neutral-muted);">neutral-body on neutral-bg</p>
          </div>

          <!-- cl-charcoal on cl-cream -->
          <div class="swatch" style="background: var(--color-cl-cream);">
            <p class="swatch-label" style="font-family: var(--font-body); color: var(--color-cl-charcoal);">Archival charcoal on cream</p>
            <p class="swatch-sub" style="color: var(--color-cl-charcoal); opacity: 0.6;">cl-charcoal on cl-cream</p>
          </div>

          <!-- tda-teal heading on neutral-bg -->
          <div class="swatch" style="background: var(--color-neutral-bg);">
            <p class="swatch-label" style="font-family: var(--font-display); font-size: var(--text-lg); color: var(--color-tda-teal);">TDA teal heading</p>
            <p class="swatch-sub" style="color: var(--color-neutral-muted);">tda-teal on neutral-bg</p>
          </div>

          <!-- cl-red heading on neutral-bg -->
          <div class="swatch" style="background: var(--color-neutral-bg);">
            <p class="swatch-label" style="font-family: var(--font-display); font-size: var(--text-lg); color: var(--color-cl-red);">CL archival red heading</p>
            <p class="swatch-sub" style="color: var(--color-neutral-muted);">cl-red on neutral-bg</p>
          </div>
        </div>
      </section>

      <hr class="divider" />

      <!-- ═══ 7. KATEX MATH SPECIMENS ══════════════════════════════════════ -->
      <section class="section">
        <p class="section-label">7. Math Specimens (Task 1.7 — KaTeX compile-time rendering)</p>

        <div class="specimen-row" style="flex-direction: column; align-items: flex-start; gap: var(--space-4);">
          <!-- Inline math: verifies Source Serif 4 body text / KaTeX harmony -->
          <p style="font-family: var(--font-body); font-size: var(--text-base); line-height: var(--leading-relaxed);">
            Inline example — standardised score: <span set:html={mathInline} />
          </p>

          <!-- Display math: verifies KaTeX block rendering at body width -->
          <div class="prose" style="width: 100%; max-width: var(--measure-prose);">
            <Fragment set:html={mathDisplay} />
          </div>

          <p style="font-family: var(--font-ui); font-size: var(--text-xs); color: var(--color-neutral-muted); font-style: italic;">
            Rendered via <code>rehype-katex</code> (compile-time) — zero client-side KaTeX JS. Verifies Source Serif 4 / KaTeX Computer Modern harmony.
          </p>
        </div>
      </section>

    </div><!-- .page-wrap -->
</BaseLayout>
