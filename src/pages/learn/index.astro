---
/**
 * src/pages/learn/index.astro — Task 4.1 — Agent_Design_Templates
 *
 * Learning Hub index: displays four learning path cards with placeholder
 * progress bars, plus a prominent link to the interactives gallery.
 * Progress bar state is visual-only; Task 4.2 will wire real data.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import PathProgressBar from '@components/learn/PathProgressBar';

interface PathCard {
  slug: string;
  title: string;
  audience: string;
  moduleCount: number;
  estimatedTime: string;
  palette: 'tda' | 'cl';
  available: boolean;
}

const paths: PathCard[] = [
  {
    slug: 'topology-social-scientists',
    title: 'Topology for Social Scientists',
    audience: 'Social researchers with no mathematics background',
    moduleCount: 8,
    estimatedTime: '~4 hours',
    palette: 'tda',
    available: true,
  },
  {
    slug: 'mathematics-of-poverty',
    title: 'Mathematics of Poverty',
    audience: 'Policy analysts and economists',
    moduleCount: 8,
    estimatedTime: '~4 hours',
    palette: 'cl',
    available: true,
  },
  {
    slug: 'tda-methods',
    title: 'TDA Methods',
    audience: 'Data scientists and mathematicians',
    moduleCount: 9,
    estimatedTime: '~5 hours',
    palette: 'tda',
    available: false,
  },
  {
    slug: 'data-justice',
    title: 'Data Justice',
    audience: 'Researchers, activists, and policymakers',
    moduleCount: 9,
    estimatedTime: '~5 hours',
    palette: 'cl',
    available: false,
  },
];
---

<BaseLayout
  title="Learning Paths"
  description="Structured learning paths connecting topological data analysis to poverty measurement research."
  section="learn"
>
  <div class="container-prose--wide learn-hub">

    <header class="learn-hub__header">
      <h1 class="learn-hub__title">Learning Paths</h1>
      <p class="learn-hub__intro">
        This learning hub bridges two intertwined projects: the history of poverty
        measurement (<em>Counting Lives</em>) and the mathematics of topological data
        analysis. Each path is self-contained — you can follow the mathematics through
        TDA or approach the same ideas via their political and historical context.
        The paths are designed to be complementary: concepts introduced in one illuminate
        the other.
      </p>
    </header>

    <section aria-label="Learning paths" class="learn-hub__paths">
      <ul class="path-grid">
        {paths.map((path) => {
          const cardClass = `path-card path-card--${path.palette}${path.available ? '' : ' path-card--coming-soon'}`;
          const href = path.available ? `/learn/${path.slug}` : '#';
          const ariaLabel = path.available
            ? `${path.title}: ${path.moduleCount} modules, ${path.estimatedTime}`
            : `${path.title}: coming soon`;

          return (
            <li>
              <article class={cardClass} aria-label={ariaLabel}>
                {!path.available && (
                  <span class="path-card__badge" aria-label="Coming soon">Coming soon</span>
                )}
                <div class="path-card__body">
                  <h2 class="path-card__title">
                    {path.available ? (
                      <a href={href} class="path-card__link">{path.title}</a>
                    ) : (
                      <span>{path.title}</span>
                    )}
                  </h2>
                  <p class="path-card__audience">{path.audience}</p>
                  <dl class="path-card__meta">
                    <div class="path-card__meta-item">
                      <dt>Modules</dt>
                      <dd>{path.moduleCount}</dd>
                    </div>
                    <div class="path-card__meta-item">
                      <dt>Time</dt>
                      <dd>{path.estimatedTime}</dd>
                    </div>
                  </dl>
                </div>
                {path.available && (
                  <PathProgressBar
                    client:only="react"
                    pathSlug={path.slug}
                    totalModules={path.moduleCount}
                  />
                )}
              </article>
            </li>
          );
        })}
      </ul>
    </section>

    <section aria-label="Learning resources" class="learn-hub__resources">
      <h2 class="learn-hub__resources-heading">Resources</h2>
      <ul class="resources-grid">
        <li>
          <a href="/learn/interactives/" class="resource-card resource-card--tda">
            <span class="resource-card__title">Interactive Tools</span>
            <span class="resource-card__desc">Standalone visual explorations — drag parameters, build point clouds, and compare thresholds.</span>
            <span class="resource-card__cta" aria-hidden="true">Explore →</span>
          </a>
        </li>
        <li>
          <a href="/learn/glossary/" class="resource-card resource-card--shared">
            <span class="resource-card__title">Glossary</span>
            <span class="resource-card__desc">27 terms spanning TDA and Counting Lives — each with dual definitions from both projects.</span>
            <span class="resource-card__cta" aria-hidden="true">Browse →</span>
          </a>
        </li>
        <li>
          <a href="/learn/reading-lists/" class="resource-card resource-card--cl">
            <span class="resource-card__title">Reading Lists</span>
            <span class="resource-card__desc">Five curated lists covering topology, poverty measurement, data justice, and TDA methods.</span>
            <span class="resource-card__cta" aria-hidden="true">Read →</span>
          </a>
        </li>
      </ul>
    </section>

  </div>
</BaseLayout>

<style>
  /* ── Page layout ──────────────────────────────────────────────────────── */
  .learn-hub {
    padding-top: var(--space-10);
    padding-bottom: var(--space-12);
  }

  /* ── Header ───────────────────────────────────────────────────────────── */
  .learn-hub__header {
    margin-bottom: var(--space-9);
  }

  .learn-hub__title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    line-height: var(--leading-tight);
    color: var(--color-neutral-body);
    margin: 0 0 var(--space-5);
  }

  .learn-hub__intro {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-neutral-muted);
    max-width: 70ch;
    margin: 0;
  }

  /* ── Path grid ────────────────────────────────────────────────────────── */
  .path-grid {
    list-style: none;
    margin: 0 0 var(--space-9);
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 340px), 1fr));
    gap: var(--space-6);
  }

  /* ── Path card — shared ────────────────────────────────────────────────── */
  .path-card {
    position: relative;
    background: var(--color-neutral-surface);
    border: 1px solid var(--color-neutral-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    padding: var(--space-6);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .path-card:not(.path-card--coming-soon):hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .path-card--coming-soon {
    opacity: 0.88; /* was 0.65; raised to pass WCAG 2.1 AA contrast (≥4.5:1) */
  }

  /* ── TDA palette accent (Path 1) ──────────────────────────────────────── */
  .path-card--tda {
    border-top: 4px solid var(--color-tda-teal);
  }

  .path-card--tda .path-card__progress-fill {
    background: var(--color-tda-teal);
  }

  /* ── Counting Lives palette accent (Path 2) ───────────────────────────── */
  .path-card--cl {
    border-top: 4px solid var(--color-cl-red);
  }

  .path-card--cl .path-card__progress-fill {
    background: var(--color-cl-red);
  }

  /* ── Coming soon badge ────────────────────────────────────────────────── */
  .path-card__badge {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-neutral-muted);
    background: var(--color-neutral-subtle);
    border-radius: var(--radius-full);
    padding: var(--space-1) var(--space-3);
    margin-bottom: var(--space-4);
    align-self: flex-start;
  }

  /* ── Card body ────────────────────────────────────────────────────────── */
  .path-card__body {
    flex: 1;
  }

  .path-card__title {
    font-family: var(--font-ui);
    font-size: var(--text-xl);
    font-weight: 600;
    line-height: var(--leading-snug);
    color: var(--color-neutral-body);
    margin: 0 0 var(--space-3);
  }

  .path-card__link {
    color: inherit;
    text-decoration: none;
  }

  .path-card__link::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius-lg);
  }

  .path-card__link:focus-visible {
    outline: none;
  }

  .path-card:focus-within .path-card__link:focus-visible::after {
    outline: 2px solid var(--color-tda-teal);
    outline-offset: 2px;
  }

  .path-card--cl:focus-within .path-card__link:focus-visible::after {
    outline-color: var(--color-cl-red);
  }

  .path-card__audience {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-neutral-muted);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-5);
  }

  /* ── Meta (module count + time) ───────────────────────────────────────── */
  .path-card__meta {
    display: flex;
    gap: var(--space-6);
    margin: 0 0 var(--space-6);
  }

  .path-card__meta-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .path-card__meta-item dt {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-neutral-muted);
  }

  .path-card__meta-item dd {
    font-family: var(--font-ui);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-neutral-body);
    margin: 0;
  }

  /* ── Progress bar ─────────────────────────────────────────────────────── */
  .path-card__progress {
    margin-top: auto;
  }

  .path-card__progress-label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--color-neutral-muted);
    margin-bottom: var(--space-2);
  }

  .path-card__progress-pct {
    font-weight: 600;
  }

  .path-card__progress-bar {
    height: 6px;
    background: var(--color-neutral-subtle);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .path-card__progress-fill {
    height: 100%;
    border-radius: var(--radius-full);
    transition: width 0.4s ease;
  }

  /* ── Resources section ────────────────────────────────────────────────── */
  .learn-hub__resources {
    margin-top: var(--space-10);
  }

  .learn-hub__resources-heading {
    font-family: var(--font-ui);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-neutral-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 var(--space-4);
  }

  .resources-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  .resource-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    border: 1px solid var(--color-neutral-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5) var(--space-6);
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .resource-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .resource-card:focus-visible {
    outline: 2px solid var(--color-tda-slate);
    outline-offset: 3px;
  }

  .resource-card--tda {
    background: var(--color-tda-warm-grey);
    border-left: 4px solid var(--color-tda-slate);
  }

  .resource-card--shared {
    background: var(--color-tda-warm-grey);
    border-left: 4px solid var(--color-tda-teal);
  }

  .resource-card--cl {
    background: var(--color-cl-cream);
    border-left: 4px solid var(--color-cl-ochre);
  }

  .resource-card__title {
    font-family: var(--font-ui);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-neutral-body);
  }

  .resource-card__desc {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-neutral-muted);
    line-height: var(--leading-normal);
    flex: 1;
  }

  .resource-card__cta {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-tda-slate);
  }

  .resource-card--cl .resource-card__cta {
    color: var(--color-cl-red);
  }

  /* ── Responsive adjustments ───────────────────────────────────────────── */
  @media (max-width: 640px) {
    .learn-hub__title {
      font-size: var(--text-3xl);
    }

    .resources-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 641px) and (max-width: 900px) {
    .resources-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
