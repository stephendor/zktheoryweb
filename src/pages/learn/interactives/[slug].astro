---
/**
 * src/pages/learn/interactives/[slug].astro — Task 3.2 — Agent_Interactive_Core
 *
 * Dynamic route that serves every interactive at:
 *   /learn/interactives/<slug>
 *
 * Build-time: getStaticPaths() queries the 'interactives' content collection
 * and generates one route per entry. Each entry's `slug` field (from its
 * frontmatter) is used as the path segment.
 *
 * Rendering: a simple BaseLayout wraps the interactive component. Components
 * are rendered via explicit slug conditionals in the template below — Astro
 * cannot statically analyse dynamic ComponentMap[slug] patterns so each
 * component is guarded by an explicit `slug === '...'` check. The
 * `client:visible` directive defers hydration until the interactive scrolls
 * into view (project convention for below-fold interactives).
 *
 * To add a new interactive:
 *   1. Create src/content/interactives/<slug>.mdx with required frontmatter.
 *   2. Import the React component above and add an explicit slug conditional
 *      in the template below (e.g. `{slug === 'my-slug' && <MyComponent client:visible />}`).
 */

import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import { NormalDistExplorer } from '@components/interactives/NormalDistExplorer';
import { PovertySimulator } from '@components/interactives/PovertySimulator';
import { PersistenceDiagramBuilderWrapper } from '@components/interactives/PersistenceDiagramBuilderWrapper';
import { MapperParameterLab } from '@components/interactives/MapperParameterLab';
import { BenefitTaperCalculator } from '@components/interactives/BenefitTaperCalculator';
import { FiltrationPlayground } from '@components/interactives/FiltrationPlayground';
// ─── Static paths ─────────────────────────────────────────────────────────────

export async function getStaticPaths() {
  const interactives = await getCollection('interactives');
  return interactives.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

// ─── Props ────────────────────────────────────────────────────────────────────

import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'interactives'>;
}

const { entry } = Astro.props;
const { title, description, slug } = entry.data;
---

<BaseLayout title={title} description={description} section="learn">
  <main class="interactive-page">
    <header class="interactive-page__header">
      <nav aria-label="Breadcrumb" class="interactive-page__breadcrumb">
        <a href="/learn">Learn</a>
        <span aria-hidden="true"> / </span>
        <span aria-current="page">{title}</span>
      </nav>
      <h1 class="interactive-page__title">{title}</h1>
      {description && <p class="interactive-page__desc">{description}</p>}
    </header>

    <section class="interactive-page__body" aria-label={title}>
      {slug === 'normal-distribution-explorer' ? (
        <NormalDistExplorer client:visible />
      ) : slug === 'poverty-threshold-simulator' ? (
        <PovertySimulator client:visible />
      ) : slug === 'persistence-diagram-builder' ? (
        <PersistenceDiagramBuilderWrapper client:visible />      ) : slug === 'mapper-parameter-lab' ? (
        <MapperParameterLab client:visible />
      ) : slug === 'benefit-taper-calculator' ? (
        <BenefitTaperCalculator client:visible />
      ) : slug === 'filtration-playground' ? (
        <FiltrationPlayground client:visible />
      ) : (
        <p class="interactive-page__missing">
          Interactive <code>{slug}</code> is not yet implemented.
        </p>
      )}
    </section>
  </main>
</BaseLayout>

<style>
  .interactive-page {
    max-width: 860px;
    margin: 0 auto;
    padding: var(--space-6) var(--space-4);
  }

  .interactive-page__header {
    margin-bottom: var(--space-6);
  }

  .interactive-page__breadcrumb {
    font-size: var(--text-sm);
    color: var(--color-neutral-muted);
    margin-bottom: var(--space-2);
  }

  .interactive-page__breadcrumb a {
    color: var(--color-tda-teal);
    text-decoration: none;
  }

  .interactive-page__breadcrumb a:hover {
    text-decoration: underline;
  }

  .interactive-page__title {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    margin: 0 0 var(--space-3);
    color: var(--color-neutral-text);
  }

  .interactive-page__desc {
    font-size: var(--text-base);
    color: var(--color-neutral-muted);
    margin: 0;
    max-width: 65ch;
    line-height: 1.6;
  }

  .interactive-page__body {
    width: 100%;
  }

  .interactive-page__missing {
    color: var(--color-neutral-muted);
    font-style: italic;
  }
</style>
