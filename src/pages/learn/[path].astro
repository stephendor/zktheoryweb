---
/**
 * src/pages/learn/[path].astro — Task 4.1 — Agent_Design_Templates
 *
 * Static path landing page template. Generates one route per available
 * learning path (topology-social-scientists, mathematics-of-poverty).
 * Module list renders with placeholder "Not started" completion state;
 * Task 4.2 will wire real progress state via the useProgress hook.
 *
 * Palette accents:
 *   topology-social-scientists → TDA Mathematical tokens (--tda-*)
 *   mathematics-of-poverty     → Counting Lives Archival tokens (--cl-*)
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import { learnPaths, availablePathSlugs } from '@data/learnPaths';
import type { LearnPath } from '@data/learnPaths';

// ─── Static paths ─────────────────────────────────────────────────────────────

export function getStaticPaths() {
  return availablePathSlugs.map((slug) => ({
    params: { path: slug },
    props: { pathData: learnPaths[slug] },
  }));
}

// ─── Props ────────────────────────────────────────────────────────────────────

interface Props {
  pathData: LearnPath;
}

const { pathData } = Astro.props;
const { title, audience, estimatedTime, palette, modules } = pathData;

const totalModules = modules.length;
const accentClass = `path-page--${palette}`;
---

<BaseLayout
  title={title}
  description={`${title} — ${audience}. ${totalModules} modules, ${estimatedTime}.`}
  section="learn"
>
  <div class={`container-prose path-page ${accentClass}`}>

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="path-page__breadcrumb">
      <a href="/learn">Learning Paths</a>
      <span aria-hidden="true"> / </span>
      <span aria-current="page">{title}</span>
    </nav>

    <!-- Path header -->
    <header class="path-page__header">
      <h1 class="path-page__title">{title}</h1>
      <dl class="path-page__meta">
        <div class="path-page__meta-item">
          <dt>Audience</dt>
          <dd>{audience}</dd>
        </div>
        <div class="path-page__meta-item">
          <dt>Modules</dt>
          <dd>{totalModules}</dd>
        </div>
        <div class="path-page__meta-item">
          <dt>Estimated time</dt>
          <dd>{estimatedTime}</dd>
        </div>
      </dl>
    </header>

    <!-- Start / Continue button (placeholder — Task 4.2 wires real state) -->
    <div class="path-page__cta">
      <a href={`/learn/${pathData.slug}/${modules[0]!.moduleNumber}`} class="path-page__start-btn">
        Start path
      </a>
    </div>

    <!-- Module list -->
    <section aria-label="Modules in this path" class="path-page__modules">
      <h2 class="path-page__modules-heading">Modules</h2>
      <ol class="module-list">
        {modules.map((mod) => (
          <li class="module-item">
            <div class="module-item__number" aria-hidden="true">{mod.moduleNumber}</div>
            <div class="module-item__content">
              <div class="module-item__header">
                <h3 class="module-item__title">{mod.title}</h3>
                <span class="module-item__status" aria-label="Completion status: Not started">
                  Not started
                </span>
              </div>
              <p class="module-item__concept">{mod.coreConcept}</p>
              <p class="module-item__time">
                <span class="sr-only">Estimated reading time:</span>
                ~{mod.estimatedMinutes} min
              </p>
            </div>
          </li>
        ))}
      </ol>
    </section>

  </div>
</BaseLayout>

<style>
  /* ── Palette variable bridge ────────────────────────────────────────────── */
  /*
   * Each palette variant sets --accent-* local custom properties so the
   * shared component styles below stay palette-agnostic.
   */
  .path-page--tda {
    --accent-primary:    var(--color-tda-teal);
    --accent-light:      var(--color-tda-teal-light);
    --accent-bg:         var(--color-tda-warm-grey);
    --accent-secondary:  var(--color-tda-slate);
  }

  .path-page--cl {
    --accent-primary:    var(--color-cl-red);
    --accent-light:      var(--color-cl-red-light);
    --accent-bg:         var(--color-cl-cream);
    --accent-secondary:  var(--color-cl-ochre);
  }

  /* ── Page layout ────────────────────────────────────────────────────────── */
  .path-page {
    padding-top: var(--space-8);
    padding-bottom: var(--space-12);
  }

  /* ── Breadcrumb ─────────────────────────────────────────────────────────── */
  .path-page__breadcrumb {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--color-neutral-muted);
    margin-bottom: var(--space-7);
  }

  .path-page__breadcrumb a {
    color: var(--accent-primary);
    text-decoration: none;
  }

  .path-page__breadcrumb a:hover {
    text-decoration: underline;
  }

  .path-page__breadcrumb a:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  /* ── Header ─────────────────────────────────────────────────────────────── */
  .path-page__header {
    padding-left: var(--space-5);
    border-left: 4px solid var(--accent-primary);
    margin-bottom: var(--space-8);
  }

  .path-page__title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    line-height: var(--leading-tight);
    color: var(--color-neutral-body);
    margin: 0 0 var(--space-5);
  }

  /* ── Meta (audience, modules, time) ────────────────────────────────────── */
  .path-page__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
    margin: 0;
  }

  .path-page__meta-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .path-page__meta-item dt {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-neutral-muted);
  }

  .path-page__meta-item dd {
    font-family: var(--font-ui);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-neutral-body);
    margin: 0;
  }

  /* ── CTA button ─────────────────────────────────────────────────────────── */
  .path-page__cta {
    margin-bottom: var(--space-10);
  }

  .path-page__start-btn {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-neutral-surface);
    background: var(--accent-primary);
    padding: var(--space-3) var(--space-7);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background 0.2s ease, box-shadow 0.2s ease;
  }

  .path-page__start-btn:hover {
    background: var(--accent-light);
    box-shadow: var(--shadow-md);
  }

  .path-page__start-btn:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 3px;
  }

  /* ── Modules section ────────────────────────────────────────────────────── */
  .path-page__modules-heading {
    font-family: var(--font-ui);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-neutral-body);
    margin: 0 0 var(--space-6);
    letter-spacing: var(--tracking-tight);
  }

  /* ── Module list ────────────────────────────────────────────────────────── */
  .module-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    counter-reset: module-counter;
  }

  /* ── Module item ────────────────────────────────────────────────────────── */
  .module-item {
    display: flex;
    gap: var(--space-5);
    background: var(--color-neutral-surface);
    border: 1px solid var(--color-neutral-border);
    border-radius: var(--radius-md);
    padding: var(--space-5) var(--space-6);
    transition: box-shadow 0.15s ease;
  }

  .module-item:hover {
    box-shadow: var(--shadow-sm);
  }

  /* ── Module number badge ────────────────────────────────────────────────── */
  .module-item__number {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-full);
    background: var(--accent-bg);
    border: 2px solid var(--accent-primary);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--accent-primary);
    line-height: 1;
  }

  /* ── Module content ─────────────────────────────────────────────────────── */
  .module-item__content {
    flex: 1;
    min-width: 0;
  }

  .module-item__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-2);
  }

  .module-item__title {
    font-family: var(--font-ui);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-neutral-body);
    line-height: var(--leading-snug);
    margin: 0;
  }

  /* ── Completion status badge ────────────────────────────────────────────── */
  .module-item__status {
    display: inline-block;
    flex-shrink: 0;
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-neutral-muted);
    background: var(--color-neutral-subtle);
    border-radius: var(--radius-full);
    padding: 2px var(--space-3);
    white-space: nowrap;
  }

  /* ── Core concept snippet ───────────────────────────────────────────────── */
  .module-item__concept {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-neutral-muted);
    line-height: var(--leading-relaxed);
    margin: 0 0 var(--space-2);
  }

  /* ── Estimated reading time ─────────────────────────────────────────────── */
  .module-item__time {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--color-neutral-muted);
    letter-spacing: var(--tracking-wide);
    margin: 0;
  }

  /* ── Screen-reader utility ──────────────────────────────────────────────── */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* ── Responsive adjustments ─────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .path-page__title {
      font-size: var(--text-3xl);
    }

    .module-item__header {
      flex-direction: column;
      align-items: flex-start;
    }

    .module-item__number {
      width: 1.75rem;
      height: 1.75rem;
    }
  }
</style>
