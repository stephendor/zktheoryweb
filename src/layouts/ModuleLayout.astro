---
/**
 * ModuleLayout.astro — Task 2.4 — Agent_Design_Templates
 *
 * Layout for Learning Path module pages. Extends BaseLayout with section="learn".
 *
 * Props:
 *   entry       — CollectionEntry<'learn-modules'>
 *   prevModule  — { slug, title } | undefined
 *   nextModule  — { slug, title } | undefined
 *   pathModules — Array<{ slug, title, status }> ordered list of all modules
 *                 in the path for the progress strip. Defaults to [].
 *
 * Rendering: uses Astro 6 render() API — `const { Content, headings } = await render(entry)`
 *
 * Structure:
 *   1. Breadcrumb nav — path label link → current module title (Step 1)
 *   2. Progress strip — numbered path nodes, current highlighted (Step 3)
 *   3. Wide prose body — .prose article + sidebar (StickyToC + Connections)
 *      3a. Interactive slot — launch link when interactive_slug defined (Step 1)
 *      3b. Content (Step 1)
 *      3c. Check Your Understanding — ExpandableCard items (Step 2)
 *      3d. Connections sidebar (Step 2)
 *   4. Module navigation — prev/next cards + back to path (Step 3)
 */

import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import StickyToC from '@components/shared/StickyToC.astro';
import { ExpandableCard } from '@components/shared/ExpandableCard';
import MarkCompleteButton from '@components/learn/MarkCompleteButton';
import { NormalDistExplorer } from '@components/interactives/NormalDistExplorer';
import { PovertySimulator } from '@components/interactives/PovertySimulator';
import { PersistenceDiagramBuilderWrapper } from '@components/interactives/PersistenceDiagramBuilderWrapper';
import { MapperParameterLab } from '@components/interactives/MapperParameterLab';
import { FiltrationPlayground } from '@components/interactives/FiltrationPlayground';
import { BenefitTaperCalculator } from '@components/interactives/BenefitTaperCalculator';
import { TDAResultsExplorer, type PresetId, VALID_PRESET_IDS, DEFAULT_PRESET_ID } from '@components/interactives/TDAResultsExplorer';
import { pathNumberToSlug } from '@data/learnPaths';

interface ModuleRef {
  slug: string;
  title: string;
}

interface PathModuleRef {
  slug: string;
  title: string;
  status: string;
}

interface Props {
  entry: CollectionEntry<'learn-modules'>;
  prevModule?: ModuleRef;
  nextModule?: ModuleRef;
  pathModules?: PathModuleRef[];
}

const { entry, prevModule, nextModule, pathModules = [] } = Astro.props;
const {
  title,
  path,
  module_number,
  core_concept,
  interactive_slug,
  tda_preset_id,
  connections,
  check_understanding,
} = entry.data;

const { Content, headings } = await render(entry);

/* ── Path → human-readable label: replace hyphens with spaces, title-case ── */
function toPathLabel(slug: string): string {
  return slug
    .split('-')
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
}
const pathLabel = toPathLabel(path);

/* ── Stable title id for aria-labelledby ── */
const titleId = 'module-title';

/* ── Convert a content-collection entry ID (e.g. 'path1-module-3') to the
   canonical module URL (/learn/topology-social-scientists/3/). Used for
   connections.modules sidebar links whose values come from MDX frontmatter.
   Falls back to /learn/ for any unrecognised pattern.
   The slug mapping is imported from src/data/learnPaths.ts — update
   pathNumberToSlug there whenever a new path is added. ── */
function moduleEntryIdToHref(entryId: string): string {
  const m = entryId.match(/^(path\d+)-module-(\d+)$/);
  if (!m) return '/learn/';
  const pathSlug = pathNumberToSlug[m[1]];
  if (!pathSlug) return '/learn/';
  return `/learn/${pathSlug}/${m[2]}/`;
}

/** Type guard — returns true when `id` is a known TDAResultsExplorer PresetId. */
function isPresetId(id: string | undefined): id is PresetId {
  return VALID_PRESET_IDS.includes(id as PresetId);
}
---

<BaseLayout title={title} description={core_concept} section="learn">

  {/* ════════════════════════════════════════════════════════════════════
      BREADCRUMB — path label link + current module title
      ════════════════════════════════════════════════════════════════════ */}
  <nav class="module-breadcrumb container-prose--wide" aria-label="Breadcrumb">
    <ol class="breadcrumb-list">
      <li class="breadcrumb-item">
        <a href="/learn/" class="breadcrumb-link">{pathLabel}</a>
      </li>
      <li class="breadcrumb-item breadcrumb-current" aria-current="page">
        {title}
      </li>
    </ol>
  </nav>

  {/* ════════════════════════════════════════════════════════════════════
      PROGRESS STRIP
      ════════════════════════════════════════════════════════════════════ */}
  {pathModules.length > 0 && (
    <div class="module-progress container-prose--wide" aria-label={`Module progress: ${module_number} of ${pathModules.length}`}>

      {/* Desktop: numbered node strip */}
      <ol class="progress-strip" aria-label="Modules in this path">
        {pathModules.map((mod, idx) => {
          const num = idx + 1;
          const isCurrent = mod.slug === entry.id;
          return (
            <li class="progress-node-item">
              <a
                href={`/learn/${path}/${num}/`}
                class:list={['progress-node', isCurrent && 'progress-node--current']}
                aria-current={isCurrent ? 'true' : undefined}
                title={mod.title}
              >
                <span class="progress-node-number" aria-hidden="true">{num}</span>
                <span class="sr-only">{mod.title}{isCurrent ? ' (current)' : ''}</span>
              </a>
            </li>
          );
        })}
      </ol>

      {/* Mobile: text counter */}
      <p class="progress-counter" aria-hidden="true">
        Module {module_number} of {pathModules.length}
      </p>

    </div>
  )}

  {/* ════════════════════════════════════════════════════════════════════
      BODY — wide prose container with sidebar
      ════════════════════════════════════════════════════════════════════ */}
  <div class="module-body">
    <div class="container-prose--wide">
      <div class="module-grid">

        {/* ── Main prose column ── */}
        <article
          class="module-article prose"
          aria-labelledby={titleId}
        >
          <h1 id={titleId}>{title}</h1>

          {core_concept && (
            <p class="module-core-concept">{core_concept}</p>
          )}

          <Content />

          {/* Interactive slot — rendered after prose so it follows the
              "Using the Interactive" section in the module text.
              Pedagogical order: Read → Explore → Test (check understanding). */}
          {interactive_slug && (
            <div class="module-interactive" aria-label="Interactive tool">
              {interactive_slug === 'normal-distribution-explorer' && (
                <NormalDistExplorer client:visible />
              )}
              {interactive_slug === 'poverty-threshold-simulator' && (
                <PovertySimulator client:visible />
              )}
              {interactive_slug === 'persistence-diagram-builder' && (
                <PersistenceDiagramBuilderWrapper client:visible />
              )}
              {interactive_slug === 'mapper-parameter-lab' && (
                <MapperParameterLab client:visible />
              )}
              {interactive_slug === 'filtration-playground' && (
                <FiltrationPlayground client:visible />
              )}
              {interactive_slug === 'benefit-taper-calculator' && (
                <BenefitTaperCalculator client:visible />
              )}
              {interactive_slug === 'tda-results-explorer' && (
                <TDAResultsExplorer presetId={isPresetId(tda_preset_id) ? tda_preset_id : DEFAULT_PRESET_ID} client:visible />
              )}
              {/* Fallback link for any interactive without a registered component */}
              {!['normal-distribution-explorer', 'poverty-threshold-simulator', 'persistence-diagram-builder', 'mapper-parameter-lab', 'filtration-playground', 'benefit-taper-calculator', 'tda-results-explorer'].includes(interactive_slug) && (
                <a href={`/learn/interactives/${interactive_slug}/`} class="interactive-launch-link">
                  Launch interactive →
                </a>
              )}
            </div>
          )}

          {/* ── Check Your Understanding ── */}
          {check_understanding.length > 0 && (
            <section class="check-understanding" aria-labelledby="reflection-heading">
              <h2 id="reflection-heading">Check Your Understanding</h2>
              {check_understanding.map((item) => (
                <ExpandableCard
                  client:visible
                  title={item.question}
                  detail={item.answer}
                  accentColor="var(--color-tda-slate)"
                />
              ))}
            </section>
          )}

          {/* ── Mark Complete button ── */}
          <MarkCompleteButton
            client:only="react"
            pathSlug={path}
            moduleSlug={String(module_number)}
            nextModuleHref={nextModule ? `/learn/${path}/${module_number + 1}/` : undefined}
          />

        </article>

        {/* ── Sidebar column ── */}
        <aside class="module-sidebar" aria-label="Module navigation sidebar">
          <StickyToC headings={headings} section="learn" />

          {/* ── Connections ── */}
          {(connections.chapters.length > 0 || connections.papers.length > 0 ||
            connections.modules.length > 0 || connections.methods.length > 0) && (
            <div class="connections-panel">
              <hr class="sidebar-divider" aria-hidden="true" />
              <h2 class="connections-heading">Related</h2>

              {connections.chapters.length > 0 && (
                <div class="connections-group">
                  <h3 class="connections-group-label">Chapters</h3>
                  <ul class="connections-list">
                    {connections.chapters.map((n) => (
                      <li>
                        <a
                          href={`/counting-lives/chapters/ch-${String(n).padStart(2, '0')}/`}
                          class="connections-link"
                        >
                          Chapter {n}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {connections.papers.length > 0 && (
                <div class="connections-group">
                  <h3 class="connections-group-label">Papers</h3>
                  <ul class="connections-list">
                    {connections.papers.map((n) => (
                      <li>
                        <a
                          href={`/tda/papers/paper-${n}/`}
                          class="connections-link"
                        >
                          Paper {n}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {connections.methods.length > 0 && (
                <div class="connections-group">
                  <h3 class="connections-group-label">Methods</h3>
                  <ul class="connections-list">
                    {connections.methods.map((slug) => (
                      <li>
                        <a
                          href={`/tda/methods/${slug}/`}
                          class="connections-link"
                        >
                          {slug}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {connections.modules.length > 0 && (
                <div class="connections-group">
                  <h3 class="connections-group-label">Modules</h3>
                  <ul class="connections-list">
                    {connections.modules.map((slug) => (
                      <li>
                        <a
                          href={moduleEntryIdToHref(slug)}
                          class="connections-link"
                        >
                          {slug}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

            </div>
          )}
        </aside>

      </div>
    </div>
  </div>

  {/* ════════════════════════════════════════════════════════════════════
      MODULE NAVIGATION — prev / next + back to path
      ════════════════════════════════════════════════════════════════════ */}
  {(prevModule || nextModule) && (
    <nav class="module-nav container-prose--wide" aria-label="Module navigation">
      <div class="module-nav-inner">

        {prevModule ? (
          <a href={`/learn/${path}/${module_number - 1}/`} class="module-nav-link module-nav-prev">
            <span class="nav-direction" aria-hidden="true">←</span>
            <span class="nav-meta">Previous module</span>
            <span class="nav-title">{prevModule.title}</span>
          </a>
        ) : (
          <div aria-hidden="true" />
        )}

        {nextModule ? (
          <a href={`/learn/${path}/${module_number + 1}/`} class="module-nav-link module-nav-next">
            <span class="nav-direction" aria-hidden="true">→</span>
            <span class="nav-meta">Next module</span>
            <span class="nav-title">{nextModule.title}</span>
          </a>
        ) : (
          <div aria-hidden="true" />
        )}

      </div>

      <div class="module-nav-back">
        <a href="/learn/" class="back-to-path-link">↑ Back to {pathLabel}</a>
      </div>
    </nav>
  )}

  {/* Back to path even when no prev/next */}
  {!prevModule && !nextModule && (
    <div class="module-nav-solo container-prose--wide">
      <a href="/learn/" class="back-to-path-link">↑ Back to {pathLabel}</a>
    </div>
  )}

</BaseLayout>

<style>
  /* ══ Breadcrumb ══════════════════════════════════════════════════════════ */
  .module-breadcrumb {
    padding-top: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-neutral-border);
  }

  .breadcrumb-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
    margin: 0;
    padding: 0;
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--color-neutral-muted);
  }

  .breadcrumb-item:not(:last-child)::after {
    content: '/';
    margin-left: var(--space-2);
    color: var(--color-neutral-border);
  }

  .breadcrumb-link {
    color: var(--color-tda-slate);
    text-decoration: none;
  }

  .breadcrumb-link:hover {
    text-decoration: underline;
    color: var(--color-tda-teal);
  }

  .breadcrumb-current {
    color: var(--color-neutral-body);
    font-weight: 500;
  }

  /* ══ Body layout ══════════════════════════════════════════════════════════ */
  .module-body {
    padding-top: var(--space-10);
    padding-bottom: var(--space-12);
  }

  .module-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .module-grid {
      grid-template-columns: 1fr var(--sidenote-width);
    }
  }

  /* ══ Article ═════════════════════════════════════════════════════════════ */
  .module-article {
    min-width: 0; /* prevent grid blowout from wide children */
  }

  .module-article h1 {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--color-neutral-body);
    margin: 0 0 var(--space-3) 0;
  }

  .module-core-concept {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-style: italic;
    color: var(--color-neutral-muted);
    line-height: var(--leading-relaxed);
    margin: 0 0 var(--space-7) 0;
    max-width: 60ch;
  }

  /* ══ Interactive slot ════════════════════════════════════════════════════ */
  .module-interactive {
    background-color: var(--color-tda-warm-grey);
    border-left: 4px solid var(--color-tda-teal);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    margin-top: var(--space-8);
    margin-bottom: var(--space-8);
    overflow: hidden;
    min-height: 320px;
  }

  /* On desktop, break the interactive out of the prose column so it fills
     the full module-grid row (article + gap + sidenote = container inner width). */
  @media (min-width: 1024px) {
    .module-interactive {
      margin-right: calc(-1 * (var(--sidenote-width) + var(--space-8)));
    }
  }

  .interactive-launch-link {
    font-family: var(--font-ui);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-tda-teal);
    text-decoration: none;
    letter-spacing: var(--tracking-wide);
  }

  .interactive-launch-link:hover {
    color: var(--color-tda-slate);
    text-decoration: underline;
  }

  .interactive-launch-link:focus-visible {
    outline: 2px solid var(--color-tda-teal);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  /* ══ Check Your Understanding ════════════════════════════════════════════ */
  .check-understanding {
    margin-top: var(--space-10);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-neutral-border);
  }

  .check-understanding h2 {
    font-family: var(--font-ui);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-neutral-body);
    margin: 0 0 var(--space-5) 0;
  }

  /* ══ Sidebar ═════════════════════════════════════════════════════════════ */
  .module-sidebar {
    min-width: 0;
  }

  /* ══ Connections panel ═══════════════════════════════════════════════════ */
  .sidebar-divider {
    border: none;
    border-top: 1px solid var(--color-neutral-border);
    margin: var(--space-6) 0;
  }

  .connections-heading {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-neutral-muted);
    margin: 0 0 var(--space-4) 0;
  }

  .connections-group {
    margin-bottom: var(--space-4);
  }

  .connections-group-label {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-tda-slate);
    margin: 0 0 var(--space-2) 0;
  }

  .connections-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .connections-link {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--color-tda-teal);
    text-decoration: none;
    line-height: var(--leading-snug);
  }

  .connections-link:hover {
    text-decoration: underline;
    color: var(--color-tda-slate);
  }

  .connections-link:focus-visible {
    outline: 2px solid var(--color-tda-teal);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  /* ══ Progress strip ══════════════════════════════════════════════════════ */
  .module-progress {
    padding-top: var(--space-5);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--color-neutral-border);
  }

  /* Desktop strip — visible ≥640px */
  .progress-strip {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .progress-node-item {
    display: flex;
    align-items: center;
  }

  /* Connector line between nodes */
  .progress-node-item:not(:last-child)::after {
    content: '';
    display: block;
    width: var(--space-4);
    height: 1px;
    background-color: var(--color-neutral-border);
    margin-left: var(--space-2);
  }

  .progress-node {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-full);
    border: 2px solid var(--color-neutral-border);
    background-color: var(--color-neutral-surface);
    color: var(--color-neutral-muted);
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 600;
    text-decoration: none;
    transition: border-color 0.15s ease, background-color 0.15s ease, color 0.15s ease;
    flex-shrink: 0;
  }

  .progress-node:hover {
    border-color: var(--color-tda-teal);
    color: var(--color-tda-teal);
  }

  .progress-node:focus-visible {
    outline: 2px solid var(--color-tda-teal);
    outline-offset: 3px;
  }

  /* Current module: filled teal + ring */
  .progress-node--current {
    background-color: var(--color-tda-teal);
    border-color: var(--color-tda-teal);
    color: #fff;
    box-shadow: 0 0 0 3px var(--color-neutral-bg), 0 0 0 5px var(--color-tda-teal);
  }

  .progress-node--current:hover {
    background-color: var(--color-tda-teal);
    color: #fff;
  }

  /* Mobile counter — hidden on desktop */
  .progress-counter {
    display: none;
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--color-neutral-muted);
    margin: 0;
  }

  /* Below 640px: hide strip, show counter */
  @media (max-width: 639px) {
    .progress-strip {
      display: none;
    }

    .progress-counter {
      display: block;
    }
  }

  /* ══ Screen-reader only utility ══════════════════════════════════════════ */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* ══ Module navigation ═══════════════════════════════════════════════════ */
  .module-nav {
    padding-top: var(--space-8);
    padding-bottom: var(--space-10);
    border-top: 1px solid var(--color-neutral-border);
  }

  .module-nav-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }

  @media (max-width: 640px) {
    .module-nav-inner {
      grid-template-columns: 1fr;
    }
  }

  .module-nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-5);
    border: 1px solid var(--color-neutral-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    background-color: var(--color-neutral-surface);
  }

  .module-nav-link:hover {
    border-color: var(--color-tda-slate);
    box-shadow: var(--shadow-sm);
  }

  .module-nav-link:focus-visible {
    outline: 2px solid var(--color-tda-slate);
    outline-offset: 2px;
  }

  .module-nav-next {
    text-align: right;
  }

  .nav-direction {
    font-size: var(--text-xl);
    color: var(--color-tda-slate);
    line-height: 1;
  }

  .nav-meta {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-neutral-muted);
  }

  .nav-title {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-neutral-body);
    line-height: var(--leading-snug);
  }

  /* Back to path */
  .module-nav-back {
    margin-top: var(--space-6);
    text-align: center;
  }

  .module-nav-solo {
    padding-top: var(--space-8);
    padding-bottom: var(--space-10);
    border-top: 1px solid var(--color-neutral-border);
    text-align: center;
  }

  .back-to-path-link {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-tda-slate);
    text-decoration: none;
